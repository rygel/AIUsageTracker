<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:AIUsageTracker.UI.Slim.Converters">

    <!-- Value Converters -->
    <converters:PercentageToColorConverter x:Key="PercentageToColorConverter"/>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" Invert="True"/>
    <converters:PrivacyMaskConverter x:Key="PrivacyMaskConverter"/>
    <converters:RelativeTimeConverter x:Key="RelativeTimeConverter"/>
    <converters:RelativeTimeConverter x:Key="RelativeTimeWithParensConverter" IncludeParentheses="True"/>
    <converters:PercentageToWidthConverter x:Key="PercentageToWidthConverter"/>
    <converters:RemainingPercentageConverter x:Key="RemainingPercentageConverter"/>
    <converters:StatusToneToColorConverter x:Key="StatusToneToColorConverter"/>
    <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
    <converters:NullToVisibilityConverter x:Key="InvertedNullToVisibilityConverter" Invert="True"/>

</ResourceDictionary>
