<Window x:Class="AIUsageTracker.UI.Slim.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AIUsageTracker.UI.Slim.ViewModels"
        xmlns:converters="clr-namespace:AIUsageTracker.UI.Slim.Converters"
        Title="AI Usage Tracker" Height="400" Width="380"
        MinWidth="320" MinHeight="300"
        WindowStyle="None" ResizeMode="CanResize"
        Background="{DynamicResource Background}"
        Foreground="{DynamicResource PrimaryText}"
        ShowInTaskbar="False"
        Topmost="True"
        Icon="Assets/app_icon.ico"
        KeyDown="OnKeyDown">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="5"
                      GlassFrameThickness="0"
                      CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Sub-Provider Card Template -->
        <DataTemplate x:Key="SubProviderCardTemplate" DataType="{x:Type vm:SubProviderCardViewModel}">
            <Grid Height="20" Margin="20,0,0,2" Background="Transparent">
                <!-- Progress Layer -->
                <Grid Visibility="{Binding HasProgress, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding IndicatorWidth, Converter={StaticResource PercentageToWidthConverter}}"/>
                        <ColumnDefinition Width="{Binding IndicatorWidth, Converter={StaticResource RemainingPercentageConverter}}"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Opacity="0.3" Background="{DynamicResource ProgressBarGreen}"/>
                </Grid>

                <!-- Content -->
                <DockPanel Margin="6,0" LastChildFill="False">
                    <!-- Bullet marker -->
                    <Border DockPanel.Dock="Left" Width="4" Height="4" CornerRadius="2"
                            Background="{DynamicResource SecondaryText}" Margin="2,0,10,0"
                            VerticalAlignment="Center"/>

                    <!-- Reset time on the right -->
                    <TextBlock DockPanel.Dock="Right" Text="{Binding ResetText}"
                               Visibility="{Binding ResetText, Converter={StaticResource NullToVisibilityConverter}}"
                               FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource StatusTextWarning}"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>

                    <!-- Value on the right -->
                    <TextBlock DockPanel.Dock="Right" Text="{Binding DisplayValue}"
                               FontSize="10" Foreground="{DynamicResource TertiaryText}"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>

                    <!-- Name on the left -->
                    <TextBlock DockPanel.Dock="Left" Text="{Binding DisplayName}"
                               FontSize="10" Foreground="{DynamicResource SecondaryText}"
                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                </DockPanel>
            </Grid>
        </DataTemplate>

        <!-- Provider Card Template -->
        <DataTemplate x:Key="ProviderCardTemplate" DataType="{x:Type vm:ProviderCardViewModel}">
            <StackPanel>
                <Grid Height="24" Margin="0,1" Background="Transparent" Tag="{Binding ProviderId}">
                    <!-- Background card for non-progress items -->
                    <Border Background="{DynamicResource CardBackground}"
                            Visibility="{Binding ShouldShowProgress, Converter={StaticResource InvertedBoolToVisibilityConverter}}"/>

                    <!-- Progress Background Layer -->
                    <Grid Visibility="{Binding ShouldShowProgress, Converter={StaticResource BoolToVisibilityConverter}}">
                        <!-- Single progress bar for non-dual-quota providers -->
                        <Grid Visibility="{Binding HasDualQuotaBuckets, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ProgressPercentage, Converter={StaticResource PercentageToWidthConverter}}"/>
                                <ColumnDefinition Width="{Binding ProgressPercentage, Converter={StaticResource RemainingPercentageConverter}}"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Opacity="0.45">
                                <Border.Background>
                                    <MultiBinding Converter="{StaticResource PercentageToColorConverter}">
                                        <Binding Path="UsedPercent"/>
                                        <Binding Path="YellowThreshold"/>
                                        <Binding Path="RedThreshold"/>
                                        <Binding Path="IsQuotaBased"/>
                                    </MultiBinding>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <!-- Dual progress bars for dual-quota providers -->
                        <Grid Visibility="{Binding HasDualQuotaBuckets, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <!-- Primary quota row -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding PrimaryUsedPercent, Converter={StaticResource PercentageToWidthConverter}}"/>
                                    <ColumnDefinition Width="{Binding PrimaryUsedPercent, Converter={StaticResource RemainingPercentageConverter}}"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Opacity="0.55">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource PercentageToColorConverter}">
                                            <Binding Path="PrimaryUsedPercent"/>
                                            <Binding Path="YellowThreshold"/>
                                            <Binding Path="RedThreshold"/>
                                            <Binding Path="IsQuotaBased"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>
                            </Grid>
                            <!-- Secondary quota row -->
                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding SecondaryUsedPercent, Converter={StaticResource PercentageToWidthConverter}}"/>
                                    <ColumnDefinition Width="{Binding SecondaryUsedPercent, Converter={StaticResource RemainingPercentageConverter}}"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Opacity="0.35">
                                    <Border.Background>
                                        <MultiBinding Converter="{StaticResource PercentageToColorConverter}">
                                            <Binding Path="SecondaryUsedPercent"/>
                                            <Binding Path="YellowThreshold"/>
                                            <Binding Path="RedThreshold"/>
                                            <Binding Path="IsQuotaBased"/>
                                        </MultiBinding>
                                    </Border.Background>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Content Overlay -->
                    <DockPanel Margin="6,0" LastChildFill="False">
                        <!-- Reset Badge (Right) -->
                        <TextBlock DockPanel.Dock="Right" Text="{Binding ResetBadgeText}"
                                   Visibility="{Binding ResetBadgeText, Converter={StaticResource NullToVisibilityConverter}}"
                                   FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource StatusTextWarning}"
                                   Margin="10,0,0,0" VerticalAlignment="Center"/>

                        <!-- Status Text (Right) -->
                        <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}"
                                   FontSize="10" Margin="10,0,0,0" VerticalAlignment="Center"
                                   Foreground="{Binding StatusTone, Converter={StaticResource StatusToneToColorConverter}}"/>

                        <!-- Provider Name (Left) -->
                        <TextBlock DockPanel.Dock="Left" FontSize="11" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource TertiaryText}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="{Binding DisplayName, Mode=OneWay}" Foreground="{DynamicResource PrimaryText}"/>
                            <Run Text="{Binding AccountDisplay, Mode=OneWay, StringFormat=' [{0}]'}"
                                 Foreground="{DynamicResource SecondaryText}" FontStyle="Italic" FontWeight="Normal">
                                <Run.Style>
                                    <Style TargetType="Run">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasAccountName}" Value="False">
                                                <Setter Property="Text" Value=""/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Run.Style>
                            </Run>
                        </TextBlock>
                    </DockPanel>
                </Grid>

                <!-- Sub-provider details (collapsible) -->
                <ItemsControl ItemsSource="{Binding Details}"
                              ItemTemplate="{StaticResource SubProviderCardTemplate}"
                              Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </DataTemplate>

        <!-- Collapsible Section Template -->
        <DataTemplate x:Key="CollapsibleSectionTemplate" DataType="{x:Type vm:CollapsibleSectionViewModel}">
            <StackPanel>
                <!-- Section Header -->
                <Grid Margin="{Binding HeaderMargin}" Cursor="Hand">
                    <Grid.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandedCommand}"/>
                    </Grid.InputBindings>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Toggle symbol -->
                    <TextBlock Grid.Column="0" Text="{Binding ToggleSymbol}"
                               FontSize="{Binding FontSize}" Foreground="{Binding AccentBrush}"
                               Margin="0,0,5,0" Opacity="{Binding ToggleOpacity}"
                               VerticalAlignment="Center"/>
                    <!-- Title -->
                    <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                               FontSize="10" FontWeight="{Binding FontWeight}"
                               Foreground="{Binding TitleBrush}" Margin="0,0,10,0"
                               VerticalAlignment="Center"/>
                    <!-- Separator line -->
                    <Border Grid.Column="2" Height="1" Background="{Binding AccentBrush}"
                            Opacity="{Binding LineOpacity}" VerticalAlignment="Center"/>
                </Grid>

                <!-- Section Items -->
                <ItemsControl ItemsSource="{Binding Items}"
                              ItemTemplate="{StaticResource ProviderCardTemplate}"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Compact Header -->
            <Border x:Name="HeaderBorder" Background="{DynamicResource HeaderBackground}" Padding="8,6" Grid.Row="0">
                <DockPanel>
                    <Image Source="Assets/app_icon.ico" Width="16" Height="16" Margin="0,0,6,0" DockPanel.Dock="Left"/>
                    <TextBlock Text="AI Usage Tracker" FontSize="13" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryText}" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="VersionText" Text="v..." FontSize="10" Foreground="{DynamicResource TertiaryText}" VerticalAlignment="Center" Margin="6,1,0,0" DockPanel.Dock="Left"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="PrivacyBtn" Content="&#xE785;" Click="PrivacyBtn_Click" Background="Transparent" Foreground="{DynamicResource SecondaryText}" Width="26" Margin="0,0,8,0" ToolTip="Toggle Privacy Mode (Ctrl+P)" FontFamily="Segoe MDL2 Assets" FontSize="14" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="X" Click="CloseBtn_Click" Background="Transparent" Foreground="{DynamicResource SecondaryText}" Width="18" FontSize="12" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Update Notification (hidden by default) -->
            <Border x:Name="UpdateNotificationBanner" Grid.Row="1" Background="{DynamicResource AccentColor}" Padding="6,3" Visibility="Collapsed">
                <DockPanel>
                    <TextBlock x:Name="UpdateText" Text="Update available!" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Changelog" HorizontalAlignment="Right" Click="ViewChangelogBtn_Click" Background="{DynamicResource ButtonBackground}" Foreground="White" FontSize="10" Padding="6,2" Margin="8,0,0,0" Cursor="Hand" WindowChrome.IsHitTestVisibleInChrome="True"/>
                        <Button Content="Download" HorizontalAlignment="Right" Click="UpdateBtn_Click" Background="{DynamicResource ButtonBackground}" Foreground="White" FontSize="10" Padding="6,2" Margin="8,0,0,0" Cursor="Hand" WindowChrome.IsHitTestVisibleInChrome="True"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Provider List - No padding for compact view -->
            <ScrollViewer x:Name="ProvidersScrollViewer" Grid.Row="2" Padding="6,4" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ProvidersList">
                    <TextBlock Text="Loading..." Foreground="{DynamicResource TertiaryText}" HorizontalAlignment="Center" FontSize="11"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Compact Footer -->
            <Border x:Name="FooterBorder" Grid.Row="3" Background="{DynamicResource FooterBackground}" Padding="8,6">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="0,0,10,0">
                        <!-- Status LED Indicator -->
                        <Ellipse x:Name="StatusLed" Width="8" Height="8" Fill="{DynamicResource SecondaryText}" VerticalAlignment="Center" Margin="0,0,6,0"
                                 ToolTip="Last update: Never"/>
                        <TextBlock x:Name="StatusText" Text="" FontSize="10" Foreground="{DynamicResource SecondaryText}" 
                                   VerticalAlignment="Center" ToolTip="Last update: Never"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <CheckBox x:Name="AlwaysOnTopCheck" 
                                  Content="Top" 
                                  IsChecked="True"
                                  Foreground="{DynamicResource SecondaryText}" 
                                  VerticalAlignment="Center"
                                  FontSize="11"
                                  Margin="0,0,8,0"
                                  Checked="AlwaysOnTop_Checked"
                                  Unchecked="AlwaysOnTop_Checked"/>
                        

                         
                          <CheckBox x:Name="ShowUsedToggle" 
                                    Content="Show Used"
                                    IsChecked="False"
                                    Foreground="{DynamicResource SecondaryText}" 
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Margin="0,0,8,0"
                                    ToolTip="Show used percentages instead of remaining percentages"
                                    Checked="ShowUsedToggle_Checked"
                                    Unchecked="ShowUsedToggle_Checked"/>
                         
                          <Button x:Name="RefreshBtn" Click="RefreshBtn_Click" Margin="0,0,8,0" ToolTip="Refresh (Ctrl+R)" Width="32" Height="28">
                              <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                          </Button>
                          <Button x:Name="WebBtn" Click="WebBtn_Click" Margin="0,0,8,0" ToolTip="Open Web UI" Width="32" Height="28">
                              <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                          </Button>
                          <Button x:Name="MonitorToggleBtn" Click="MonitorToggleBtn_Click" ToolTip="Start/Stop Monitor" Width="32" Height="28">
                              <TextBlock x:Name="MonitorToggleIcon" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                          </Button>
                          <Button x:Name="SettingsBtn" Click="SettingsBtn_Click" Margin="8,0,0,0" ToolTip="Settings" Width="32" Height="28">
                              <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center"/>
                          </Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
