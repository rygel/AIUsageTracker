@{
    var version = typeof(AIUsageTracker.Web.Services.WebDatabaseService)
        .Assembly
        .GetName()
        .Version?
        .ToString(3) ?? "dev";
}
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AI Usage Tracker</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/themes.css" />
    <script src="https://unpkg.com/htmx.org@1.9.12" crossorigin="anonymous"></script>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <span class="sidebar-brand">AI Tracker</span>
            </div>
            
            <nav class="sidebar-nav">
                <ul>
                    <li class="nav-item">
                        <a href="/" class="nav-link @(Context.Request.Path == "/" ? "active" : "")">
                            <span class="nav-text">Dashboard</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/reliability" class="nav-link @(Context.Request.Path.Value?.Contains("/reliability") == true ? "active" : "")">
                            <span class="nav-text">Reliability</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/charts" class="nav-link @(Context.Request.Path.Value?.Contains("/charts") == true ? "active" : "")">
                            <span class="nav-text">Charts</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/providers" class="nav-link @(Context.Request.Path.Value?.Contains("/providers") == true ? "active" : "")">
                            <span class="nav-text">Providers</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/history" class="nav-link @(Context.Request.Path.Value?.Contains("/history") == true ? "active" : "")">
                            <span class="nav-text">History</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/data/providers" class="nav-link @(Context.Request.Path.Value?.Contains("/data") == true ? "active" : "")">
                            <span class="nav-text">Raw Data</span>
                        </a>
                    </li>
                </ul>
            </nav>
            
            <div class="sidebar-footer">
                <div class="agent-section">
                    <div class="agent-status-row">
                        <span id="agent-status" class="agent-status">Checking...</span>
                        <button id="agent-toggle-btn" class="btn btn-sm btn-primary" onclick="toggleMonitor()">Start</button>
                    </div>
                    <div id="agent-status-detail" class="agent-status-detail">Waiting for status...</div>
                </div>
                
                <div class="theme-section">
                    <select id="theme-select" class="theme-select theme-toggle">
                        @* GENERATED-THEME-OPTIONS-START *@
                        <option value="dark">Dark</option>
                        <option value="light">Light</option>
                        <option value="corporate">Corporate</option>
                        <option value="midnight">Midnight</option>
                        <option value="dracula">Dracula</option>
                        <option value="nord">Nord</option>
                        <option value="monokai">Monokai</option>
                        <option value="one-dark">One Dark</option>
                        <option value="solarized-dark">Solarized Dark</option>
                        <option value="solarized-light">Solarized Light</option>
                        <option value="catppuccin-frappe">Catppuccin Frappe</option>
                        <option value="catppuccin-macchiato">Catppuccin Macchiato</option>
                        <option value="catppuccin-mocha">Catppuccin Mocha</option>
                        <option value="catppuccin-latte">Catppuccin Latte</option>
                        @* GENERATED-THEME-OPTIONS-END *@
                    </select>
                </div>
                <div class="sidebar-footer-text">&copy; @DateTime.Now.Year - v@version</div>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Mobile Header -->
            <header class="mobile-header">
                <button class="menu-toggle" id="menu-toggle" aria-label="Menu">
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
                <span class="mobile-title">AI Tracker</span>
            </header>

            <!-- Page Content -->
            <main class="content-wrapper">
                @RenderBody()
            </main>
        </div>
    </div>

    <!-- Overlay for mobile -->
    <div class="sidebar-overlay" id="sidebar-overlay"></div>

    <script src="~/js/theme.js"></script>
    <script src="~/js/sidebar.js"></script>
    <script>
        // Monitor status check
        let isMonitorRunning = false;

        function setStatusDetail(message, tone = '') {
            const detailEl = document.getElementById('agent-status-detail');
            if (!detailEl) return;
            detailEl.textContent = message || '';
            detailEl.classList.remove('error', 'warning');
            if (tone) {
                detailEl.classList.add(tone);
            }
        }

        function setStatusTone(statusEl, tone = '') {
            statusEl.classList.remove('running', 'degraded', 'starting', 'error', 'stopped');
            if (tone) {
                statusEl.classList.add(tone);
            }
        }
        
        async function checkMonitorStatus() {
            try {
                const res = await fetch('/api/monitor/status');
                const data = await res.json();
                const statusEl = document.getElementById('agent-status');
                const btn = document.getElementById('agent-toggle-btn');
                const serviceHealth = typeof data.serviceHealth === 'string' ? data.serviceHealth.toLowerCase() : '';
                const startupState = typeof data.startupState === 'string' ? data.startupState.toLowerCase() : '';
                const startupFailureReason = data.startupFailureReason || data.message;
                const contractWarning = data.isContractCompatible === false && typeof data.contractMessage === 'string'
                    ? data.contractMessage
                    : '';
                 
                isMonitorRunning = data.isRunning;
                 
                if (data.isRunning) {
                    if (serviceHealth === 'degraded') {
                        statusEl.textContent = 'Monitor: Running (Degraded)';
                        setStatusTone(statusEl, 'degraded');
                        const degradedMessage = data.message || `Running on port ${data.port}, but refresh health is degraded.`;
                        setStatusDetail(contractWarning ? `${degradedMessage} ${contractWarning}` : degradedMessage, 'warning');
                    } else {
                        statusEl.textContent = 'Monitor: Running';
                        setStatusTone(statusEl, 'running');
                        const runningMessage = data.message || `Healthy on port ${data.port}.`;
                        setStatusDetail(contractWarning ? `${runningMessage} ${contractWarning}` : runningMessage, contractWarning ? 'warning' : '');
                    }

                    btn.textContent = 'Stop';
                    btn.classList.remove('btn-primary');
                    btn.classList.add('btn-danger');
                } else if (startupState === 'starting') {
                    statusEl.textContent = 'Monitor: Starting';
                    setStatusTone(statusEl, 'starting');
                    setStatusDetail(data.message || 'Monitor is starting.');
                    btn.textContent = 'Start';
                    btn.classList.remove('btn-danger');
                    btn.classList.add('btn-primary');
                } else if (startupState === 'failed') {
                    statusEl.textContent = 'Monitor: Startup Failed';
                    setStatusTone(statusEl, 'error');
                    setStatusDetail(startupFailureReason || 'Monitor startup failed.', 'error');
                    btn.textContent = 'Start';
                    btn.classList.remove('btn-danger');
                    btn.classList.add('btn-primary');
                } else if (data.error === 'monitor-unreachable') {
                    statusEl.textContent = 'Monitor: Unreachable';
                    setStatusTone(statusEl, 'error');
                    setStatusDetail(data.message || `Monitor not reachable on port ${data.port}.`, 'error');
                    btn.textContent = 'Start';
                    btn.classList.remove('btn-danger');
                    btn.classList.add('btn-primary');
                } else {
                    statusEl.textContent = 'Monitor: Stopped';
                    setStatusTone(statusEl, 'stopped');
                    setStatusDetail(data.message || 'Monitor is not running.');
                    btn.textContent = 'Start';
                    btn.classList.remove('btn-danger');
                    btn.classList.add('btn-primary');
                }
            } catch {
                const statusEl = document.getElementById('agent-status');
                statusEl.textContent = 'Monitor: Unknown';
                setStatusTone(statusEl, 'error');
                setStatusDetail('Could not contact Web monitor API.', 'error');
                isMonitorRunning = false;
            }
        }
        
        async function toggleMonitor() {
            const btn = document.getElementById('agent-toggle-btn');
            btn.disabled = true;
            
            if (isMonitorRunning) {
                btn.textContent = 'Stopping...';
                setStatusDetail('Stopping monitor process...');
                try {
                    const res = await fetch('/api/monitor/stop', { method: 'POST' });
                    const data = await res.json();
                    setStatusDetail(data?.message || (res.ok ? 'Monitor stopped.' : 'Failed to stop monitor.'), res.ok ? '' : 'error');
                    if (res.ok) {
                        setTimeout(checkMonitorStatus, 1000);
                    }
                } catch (e) {
                    console.error(e);
                    setStatusDetail('Stop request failed. See browser console.', 'error');
                }
            } else {
                btn.textContent = 'Starting...';
                setStatusDetail('Starting monitor process...');
                try {
                    const res = await fetch('/api/monitor/start', { method: 'POST' });
                    const data = await res.json();
                    const statusEl = document.getElementById('agent-status');
                    const startupState = typeof data?.startupState === 'string' ? data.startupState.toLowerCase() : '';
                    if (!res.ok && startupState === 'failed') {
                        statusEl.textContent = 'Monitor: Startup Failed';
                        setStatusTone(statusEl, 'error');
                        setStatusDetail(data?.startupFailureReason || data?.message || 'Monitor startup failed.', 'error');
                    } else if (!res.ok && startupState === 'starting') {
                        statusEl.textContent = 'Monitor: Starting';
                        setStatusTone(statusEl, 'starting');
                        setStatusDetail(data?.message || 'Monitor is still starting.');
                        setTimeout(checkMonitorStatus, 1000);
                    } else if (!res.ok && data?.error === 'monitor-unreachable') {
                        statusEl.textContent = 'Monitor: Unreachable';
                        setStatusTone(statusEl, 'error');
                        setStatusDetail(data?.message || 'Monitor is not reachable.', 'error');
                    } else {
                        setStatusDetail(data?.message || (res.ok ? 'Monitor started.' : 'Failed to start monitor.'), res.ok ? '' : 'error');
                    }

                    if (res.ok) {
                        setTimeout(checkMonitorStatus, 2000);
                    }
                } catch (e) {
                    console.error(e);
                    setStatusDetail('Start request failed. See browser console.', 'error');
                }
            }
            
            setTimeout(() => {
                btn.disabled = false;
                checkMonitorStatus();
            }, 3000);
        }
        
        document.addEventListener('DOMContentLoaded', checkMonitorStatus);
        setInterval(checkMonitorStatus, 30000);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
