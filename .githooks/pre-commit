#!/usr/bin/env sh

set -eu

repo_root="$(git rev-parse --show-toplevel)"
gate="$repo_root/scripts/pre-commit-analyzer-gate.ps1"

if command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -File "$gate" -AgentOwner git-pre-commit -AgentTask changed-file-analyzer-gate
fi

if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$gate" -AgentOwner git-pre-commit -AgentTask changed-file-analyzer-gate
fi

echo "Analyzer gate requires PowerShell (pwsh or powershell.exe)." >&2
exit 1
