root = true

[*.cs]
indent_style = space
indent_size = 4
insert_final_newline = true
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_new_line_at_end_of_file = true

dot_diagnostic.IDE0005.severity = warning
dot_diagnostic.IDE0055.severity = warning
dot_diagnostic.CA1031.severity = suggestion
dot_diagnostic.CA1062.severity = error
dot_diagnostic.CA1307.severity = warning
dot_diagnostic.CA1309.severity = warning
dot_diagnostic.CA1725.severity = error
dot_diagnostic.CA2208.severity = warning
dot_diagnostic.CA2300.severity = warning

# Repo-specific guardrails like "no sync-over-async" and "no empty catch blocks"
# are enforced in architecture tests because the patterns are project-specific and
# need tighter control than generic analyzer packages provide.
dot_diagnostic.VSTHRD002.severity = warning
dot_diagnostic.VSTHRD103.severity = warning
dot_diagnostic.VSTHRD105.severity = warning
dot_diagnostic.VSTHRD110.severity = warning
dot_diagnostic.VSTHRD111.severity = none
dot_diagnostic.VSTHRD200.severity = none
dot_diagnostic.MA0002.severity = none
dot_diagnostic.MA0004.severity = none
dot_diagnostic.MA0006.severity = none
dot_diagnostic.MA0009.severity = none
dot_diagnostic.MA0011.severity = none
dot_diagnostic.MA0016.severity = none
dot_diagnostic.MA0023.severity = suggestion
dot_diagnostic.MA0039.severity = warning
dot_diagnostic.MA0004.severity = none
dot_diagnostic.MA0016.severity = none
dot_diagnostic.MA0051.severity = none
dot_diagnostic.MA0051.severity = none
dot_diagnostic.MA0074.severity = warning
dot_style_diagnostics.use_slashes_for_doc_comments = false
dot_style_diagnostics.xml_header = false
dot_style_diagnostics.separate_multiple_def_lines = false

[AIUsageTracker.Tests/**/*.cs]
dot_diagnostic.MA0074.severity = none
dot_diagnostic.MA0009.severity = none


# Suppress method length warnings - 60 line limit is arbitrary
dot_diagnostic.MA0051.severity = none
